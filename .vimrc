set shiftwidth=4
set softtabstop=4
set expandtab
set smartindent

set number
set relativenumber

set ignorecase
set smartcase
set incsearch
set hlsearch

syntax on

set laststatus=2

if (has("termguicolors"))
    set termguicolors
endif

let g:gruvbox_italic=1

set background=dark
colorscheme gruvbox
